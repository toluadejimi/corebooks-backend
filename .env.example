APP_NAME=CoreBooks
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Use true behind an HTTPS reverse proxy/tunnel if APP_URL is still http://… (avoids mixed-content redirects).
# FORCE_HTTPS=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Comma-separated emails that may edit subscription plans and review loan applications (/admin/platform/…).
SALESAPP_PLATFORM_ADMIN_EMAILS=

# Allow platform admins to run `php artisan migrate --force` from the portfolio dashboard (no SSH). Set false to disable.
SALESAPP_ALLOW_WEB_MIGRATIONS=true

# Optional: Paystack (NGN). If omitted, checkout returns offline instructions for the mobile app.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Shown when Paystack is not configured.
SALESAPP_OFFLINE_PAYMENT_INSTRUCTIONS=
